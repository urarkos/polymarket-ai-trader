# === AI API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# === Polymarket ===
# Your Ethereum private key for the wallet holding USDC on Polygon
POLYMARKET_PRIVATE_KEY=0x...
# Optional: CLOB API credentials (if using Level 2 auth)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# === Trading Settings ===
BANKROLL_USDC=1000.0          # Your total trading bankroll
MAX_BET_USDC=50.0             # Max per trade
MIN_EDGE=0.05                 # 5% minimum edge
KELLY_FRACTION=0.25           # 25% fractional Kelly
AUTO_BET_ENABLED=false        # Set to true to enable auto-pilot
SCAN_INTERVAL_MINUTES=15      # How often to scan

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./polymarket.db
